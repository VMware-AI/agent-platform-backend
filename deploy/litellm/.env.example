# Copy to .env and fill in. Never commit the real .env.
# Master key the control plane uses to drive litellm's admin API (must start sk-).
LITELLM_MASTER_KEY=sk-local-master-change-me
# Salt for encrypting stored keys in litellm's DB (any long random string).
LITELLM_SALT_KEY=local-salt-change-me-to-something-long
# Your minimax API key (used by the minimax model entry / pushed upstream).
MINIMAX_API_KEY=
