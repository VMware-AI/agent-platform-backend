# Atlas config for Ent versioned migrations (H3: prod never auto-migrates).
#
# Migration *files* are generated by Ent's native Atlas integration, not by the
# atlas-provider-ent plugin (its `ariga.io/atlas-provider-ent` import path is no
# longer resolvable, and a self-contained generator is air-gap friendly):
#
#   Generate:  ATLAS_DEV_URL=postgres://… make migrate-diff name=<change>
#              (runs ./ent/migrate/main.go — see that file)
#
# Atlas CLI is still used to apply / inspect against a target database, which
# only needs the migration directory below (no dev DB, no external schema):
#
#   Apply:     DATABASE_URL=postgres://…  make migrate-apply
#   Status:    DATABASE_URL=postgres://…  make migrate-status
#   Validate:  atlas migrate validate --env ent
#
# Docs: https://entgo.io/docs/versioned-migrations

env "ent" {
  migration {
    dir = "file://ent/migrate/migrations"
  }
  # Throwaway dev DB, only needed for `atlas migrate lint` (diffing uses the Go
  # generator above). e.g.
  #   ATLAS_DEV_URL=postgres://localhost:5432/atlas_dev?sslmode=disable
  dev = getenv("ATLAS_DEV_URL")
}
